page {
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", "Segoe UI", sans-serif;
}

.page-wrapper {
  padding: 16rpx 24rpx 32rpx;
}

.card {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.04);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #222222;
}

.card-subtitle {
  font-size: 24rpx;
  color: #999999;
}

.primary-btn {
  background: linear-gradient(135deg, #ff7a45, #ff4d4f);
  color: #ffffff;
  border-radius: 999rpx;
  font-size: 30rpx;
}

.primary-btn::after {
  border: none;
}

.secondary-btn {
  border-radius: 999rpx;
  font-size: 28rpx;
}

.tag {
  padding: 4rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  line-height: 1.6;
}

.tag-todo {
  background-color: #fff7e6;
  color: #fa8c16;
}

.tag-done {
  background-color: #e6fffb;
  color: #13c2c2;
}

.tag-repeat {
  background-color: #f9f0ff;
  color: #722ed1;
}

.status-filter {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.status-chip {
  padding: 8rpx 20rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  margin-right: 12rpx;
  background-color: #f0f0f0;
  color: #666666;
}

.status-chip.active {
  background-color: #ffefe6;
  color: #ff4d4f;
}

.list-item {
  padding: 20rpx 0;
  border-bottom: 1px solid #f0f0f0;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.list-item:last-child {
  border-bottom: none;
}

.list-item-title {
  font-size: 30rpx;
  color: #222222;
  font-weight: 500;
}

.list-item-desc {
  font-size: 24rpx;
  color: #999999;
  margin-top: 4rpx;
}

.list-item-right {
  display: flex;
  align-items: center;
}

.empty-tip {
  text-align: center;
  color: #999999;
  font-size: 26rpx;
  padding: 40rpx 0;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
  color: #333333;
}

.form-item {
  margin-bottom: 24rpx;
}

.form-label {
  font-size: 26rpx;
  color: #666666;
  margin-bottom: 8rpx;
}

.form-input,
.form-textarea {
  background-color: #ffffff;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 28rpx;
  border: 1px solid #f0f0f0;
}

.form-textarea {
  min-height: 180rpx;
}

.form-input-placeholder {
  color: #cccccc;
}

.fixed-bottom {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 16rpx 24rpx 32rpx;
  background: linear-gradient(to top, #f5f5f5, rgba(245, 245, 245, 0.9), transparent);
  box-sizing: border-box;
}

.fixed-bottom .primary-btn {
  width: 100%;
}

/**app.wxss**/
.container {
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: space-between;
  padding: 200rpx 0;
  box-sizing: border-box;
} 
